<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Management System</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root {
    --sidebar-bg: #1B1C31;
    --sidebar-hover: #2B2DFB;
    --bg-color: #F4F7FE;
    --text-main: #2B3674;
    --text-muted: #A3AED0;
    --card-radius: 20px;
  }
  * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
  body { background: var(--bg-color); margin: 0; color: var(--text-main); }

  .card-plain {
    background: #ffffff;
    border-radius: var(--card-radius);
    border: none;
    box-shadow: 0 6px 20px rgba(43, 54, 116, 0.06);
    padding: 24px;
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 280px;
    height: 100vh;
    background: var(--sidebar-bg);
    color: #ffffff;
    padding: 24px 18px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .brand-box { display: flex; align-items: center; gap: 12px; margin-bottom: 30px; padding: 0 8px; }
  .brand-logo {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, #FF9C00, #FFC048);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; color: #fff; font-size: 18px;
  }
  .brand-text .name { font-weight: 700; font-size: 16px; color: #fff; line-height: 1.1; }
  .brand-text .sub { font-size: 11px; color: var(--text-muted); }

  .nav-header { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin: 18px 8px 8px 8px; }
  .nav-link-item {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 14px; border-radius: 12px;
    color: #C8CBE8; text-decoration: none; font-size: 14px; font-weight: 500;
    margin-bottom: 4px; transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-link-item i { width: 18px; text-align: center; }
  .nav-link-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .nav-link-item.active { background: var(--sidebar-hover); color: #fff; }
  .nav-link-item.logout-link { color: #FF6969; margin-top: 10px; }
  .nav-link-item.logout-link:hover { background: rgba(255,105,105,0.12); color: #FF6969; }

  .trophy-card {
    margin-top: auto;
    background: linear-gradient(160deg, #2B2DFB, #6366F1);
    border-radius: 16px;
    padding: 18px;
    text-align: center;
    color: #fff;
  }
  .trophy-card i { font-size: 26px; margin-bottom: 8px; color: #FFC048; }
  .trophy-card .t1 { font-weight: 700; font-size: 14px; }
  .trophy-card .t2 { font-size: 11px; color: #D6D8FF; margin-top: 2px; }

  /* Main content */
  .main-content { margin-left: 280px; padding: 24px 32px 60px 32px; }

  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 26px; gap: 16px; flex-wrap: wrap;
  }
  .page-title { font-size: 22px; font-weight: 700; color: var(--text-main); margin: 0; }
  .welcome-text { font-size: 13px; color: var(--text-muted); margin: 0; }
  .topbar-actions { display: flex; align-items: center; gap: 12px; }
  .search-bar {
    background: #fff; border-radius: 14px; padding: 8px 16px;
    display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(43,54,116,0.05);
  }
  .search-bar input { border: none; outline: none; background: transparent; font-size: 13px; width: 140px; }
  .icon-btn {
    width: 42px; height: 42px; border-radius: 12px; background: #fff;
    display: flex; align-items: center; justify-content: center; position: relative;
    color: var(--text-main); box-shadow: 0 4px 12px rgba(43,54,116,0.05); border: none;
  }
  .icon-btn .badge-count {
    position: absolute; top: -4px; right: -4px; background: #FF4C61; color: #fff;
    font-size: 10px; border-radius: 50%; width: 18px; height: 18px;
    display: flex; align-items: center; justify-content: center;
  }
  .profile-btn {
    display: flex; align-items: center; gap: 10px; background: #fff; border-radius: 14px;
    padding: 6px 14px 6px 6px; box-shadow: 0 4px 12px rgba(43,54,116,0.05);
  }
  .profile-btn img { width: 32px; height: 32px; border-radius: 50%; }
  .profile-btn .p-name { font-size: 13px; font-weight: 600; color: var(--text-main); line-height: 1.1; }
  .profile-btn .p-role { font-size: 11px; color: var(--text-muted); text-transform: capitalize; }

  /* Metric cards */
  .metric-card {
    border-radius: var(--card-radius); padding: 22px; color: #fff; position: relative; overflow: hidden;
    min-height: 120px; display: flex; flex-direction: column; justify-content: space-between;
  }
  .metric-card .icon-badge {
    width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.22);
    display: flex; align-items: center; justify-content: center; font-size: 18px;
  }
  .metric-card .m-value { font-size: 26px; font-weight: 700; margin-top: 10px; }
  .metric-card .m-label { font-size: 12px; opacity: 0.9; }
  .bg-purple { background: linear-gradient(135deg, #6366F1, #8385FF); }
  .bg-green  { background: linear-gradient(135deg, #00B87C, #29D999); }
  .bg-orange { background: linear-gradient(135deg, #FF9C00, #FFB74D); }
  .bg-blue   { background: linear-gradient(135deg, #0075FF, #4DA3FF); }
  .bg-pink   { background: linear-gradient(135deg, #FF4C61, #FF7C8B); }

  .table-plain { margin-bottom: 0; }
  .table-plain th { color: var(--text-muted); font-size: 12px; text-transform: uppercase; border-bottom: 1px solid #EEF1F8; font-weight: 600; }
  .table-plain td { vertical-align: middle; font-size: 14px; border-bottom: 1px solid #F4F6FB; }
  .avatar-sm { width: 34px; height: 34px; border-radius: 50%; }

  .status-pill { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
  .status-present, .status-approved { background: rgba(0,184,124,0.12); color: #00B87C; }
  .status-absent, .status-declined { background: rgba(255,76,97,0.12); color: #FF4C61; }
  .status-pending { background: rgba(255,156,0,0.12); color: #FF9C00; }

  .btn-indigo { background: #6366F1; color: #fff; border: none; }
  .btn-indigo:hover { background: #4F46E5; color: #fff; }

  .exam-card { border-radius: 16px; border-top: 5px solid #6366F1; background: #fff; padding: 20px; box-shadow: 0 6px 16px rgba(43,54,116,0.06); }
  .exam-card .score-num { font-size: 32px; font-weight: 700; color: var(--text-main); }

  .notif-card { background: #fff; border-radius: 16px; padding: 16px 18px; display: flex; gap: 14px; align-items: flex-start; box-shadow: 0 4px 12px rgba(43,54,116,0.05); margin-bottom: 12px; }
  .notif-card i { color: #6366F1; font-size: 18px; margin-top: 3px; }
  .notif-card .n-msg { font-size: 14px; color: var(--text-main); margin: 0; }
  .notif-card .n-time { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

  @media (max-width: 992px) {
    .sidebar { display: none; }
    .main-content { margin-left: 0; }
  }
</style>
</head>
<body>

<!-- ============================ SIDEBAR ============================ -->
<div class="sidebar">
  <div class="brand-box">
    <div class="brand-logo">S</div>
    <div class="brand-text">
      <div class="name">SMS</div>
      <div class="sub">Management System</div>
    </div>
  </div>

  <a href="/app?page=dashboard" class="nav-link-item <%= page === 'dashboard' ? 'active' : '' %>">
    <i class="fa-solid fa-gauge"></i> Dashboard
  </a>

  <% if (user.role === 'admin') { %>
    <div class="nav-header">Academic</div>
    <a href="/app?page=courses" class="nav-link-item <%= page === 'courses' ? 'active' : '' %>"><i class="fa-solid fa-book"></i> Courses</a>
    <a href="/app?page=subjects" class="nav-link-item <%= page === 'subjects' ? 'active' : '' %>"><i class="fa-solid fa-layer-group"></i> Subjects</a>

    <div class="nav-header">Users</div>
    <a href="/app?page=manage_staff" class="nav-link-item <%= page === 'manage_staff' ? 'active' : '' %>"><i class="fa-solid fa-user-tie"></i> Manage Staff</a>
    <a href="/app?page=manage_students" class="nav-link-item <%= page === 'manage_students' ? 'active' : '' %>"><i class="fa-solid fa-user-graduate"></i> Manage Students</a>

    <div class="nav-header">Requests</div>
    <a href="/app?page=notifications" class="nav-link-item <%= page === 'notifications' ? 'active' : '' %>"><i class="fa-solid fa-envelope-open-text"></i> Leave Requests</a>
    <a href="/app?page=notify" class="nav-link-item <%= page === 'notify' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn"></i> Send Notification</a>
  <% } else if (user.role === 'staff') { %>
    <div class="nav-header">Academic</div>
    <a href="/app?page=take_attendance" class="nav-link-item <%= page === 'take_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-check"></i> Take Attendance</a>
    <a href="/app?page=view_attendance" class="nav-link-item <%= page === 'view_attendance' ? 'active' : '' %>"><i class="fa-solid fa-table-list"></i> View Attendance</a>
    <a href="/app?page=manage_exams" class="nav-link-item <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-pen-to-square"></i> Manage Exams</a>

    <div class="nav-header">Requests</div>
    <a href="/app?page=apply_leave" class="nav-link-item <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-day"></i> Apply Leave</a>
    <a href="/app?page=staff_notifs" class="nav-link-item <%= page === 'staff_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notifications</a>

    <div class="nav-header">Others</div>
    <a href="/app?page=feedback" class="nav-link-item <%= page === 'feedback' ? 'active' : '' %>"><i class="fa-solid fa-comment-dots"></i> Feedback</a>
  <% } else if (user.role === 'student') { %>
    <div class="nav-header">Academic</div>
    <a href="/app?page=my_attendance" class="nav-link-item <%= page === 'my_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-check"></i> My Attendance</a>
    <a href="/app?page=exam_results" class="nav-link-item <%= page === 'exam_results' ? 'active' : '' %>"><i class="fa-solid fa-award"></i> Exam Results</a>

    <div class="nav-header">Requests</div>
    <a href="/app?page=apply_leave" class="nav-link-item <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-day"></i> Apply Leave</a>
    <a href="/app?page=student_notifs" class="nav-link-item <%= page === 'student_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notifications</a>

    <div class="nav-header">Others</div>
    <a href="/app?page=feedback" class="nav-link-item <%= page === 'feedback' ? 'active' : '' %>"><i class="fa-solid fa-comment-dots"></i> Feedback</a>
  <% } %>

  <div class="trophy-card">
    <i class="fa-solid fa-trophy"></i>
    <div class="t1">Keep it up!</div>
    <div class="t2">You're doing great this term.</div>
  </div>

  <a href="/logout" class="nav-link-item logout-link"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<!-- ============================ MAIN CONTENT ============================ -->
<div class="main-content">

  <div class="topbar">
    <div>
      <h1 class="page-title"><%= page.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></h1>
      <p class="welcome-text">Welcome back, <%= user.full_name %></p>
    </div>
    <div class="topbar-actions">
      <div class="search-bar">
        <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted); font-size:13px;"></i>
        <input type="text" placeholder="Search...">
      </div>
      <button class="icon-btn"><i class="fa-regular fa-calendar"></i></button>
      <button class="icon-btn">
        <i class="fa-regular fa-bell"></i>
        <span class="badge-count">3</span>
      </button>
      <div class="profile-btn">
        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.full_name) %>&background=6366F1&color=fff" alt="avatar">
        <div>
          <div class="p-name"><%= user.full_name %></div>
          <div class="p-role"><%= user.role %></div>
        </div>
      </div>
    </div>
  </div>

  <% if (success_msg) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success_msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- ============================ PAGE CONTENT ============================ -->

  <% if (page === 'dashboard') { %>
    <div class="row g-3 mb-3">
      <div class="col-md-4 col-lg">
        <div class="metric-card bg-purple">
          <div class="icon-badge"><i class="fa-solid fa-book"></i></div>
          <div><div class="m-value"><%= data.total_courses !== undefined ? data.total_courses : 12 %></div><div class="m-label">Total Courses</div></div>
        </div>
      </div>
      <div class="col-md-4 col-lg">
        <div class="metric-card bg-blue">
          <div class="icon-badge"><i class="fa-solid fa-layer-group"></i></div>
          <div><div class="m-value"><%= data.total_subjects !== undefined ? data.total_subjects : 34 %></div><div class="m-label">Total Subjects</div></div>
        </div>
      </div>
      <div class="col-md-4 col-lg">
        <div class="metric-card bg-green">
          <div class="icon-badge"><i class="fa-solid fa-clipboard-check"></i></div>
          <div><div class="m-value"><%= data.att_count !== undefined ? data.att_count : 128 %></div><div class="m-label">Attendance Records</div></div>
        </div>
      </div>
      <div class="col-md-4 col-lg">
        <div class="metric-card bg-orange">
          <div class="icon-badge"><i class="fa-solid fa-user-graduate"></i></div>
          <div><div class="m-value"><%= data.total_students !== undefined ? data.total_students : 240 %></div><div class="m-label">Total Students</div></div>
        </div>
      </div>
      <div class="col-md-4 col-lg">
        <div class="metric-card bg-pink">
          <div class="icon-badge"><i class="fa-solid fa-user-tie"></i></div>
          <div><div class="m-value"><%= data.total_staff !== undefined ? data.total_staff : 18 %></div><div class="m-label">Total Staff</div></div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-8">
        <div class="card-plain">
          <h6 class="mb-3 fw-bold">Attendance Overview</h6>
          <div style="position:relative; height:280px;">
            <canvas id="attendanceChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card-plain">
          <h6 class="mb-3 fw-bold">Performance Metrics</h6>
          <div style="position:relative; height:280px;">
            <canvas id="performanceChart"></canvas>
          </div>
        </div>
      </div>
    </div>

  <% } else if (page === 'courses' || page === 'subjects') { %>
    <div class="row g-3">
      <div class="col-lg-4">
        <div class="card-plain">
          <h6 class="fw-bold mb-3">Add <%= page === 'courses' ? 'Course' : 'Subject' %></h6>
          <form method="POST" action="/app?page=<%= page %>">
            <% if (page === 'courses') { %>
              <input type="hidden" name="action" value="add_course">
              <div class="mb-3">
                <label class="form-label">Course Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>
            <% } else { %>
              <input type="hidden" name="action" value="add_subject">
              <div class="mb-3">
                <label class="form-label">Subject Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Course</label>
                <select name="course_id" class="form-select" required>
                  <% data.courses.forEach(c => { %>
                    <option value="<%= c._id %>"><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
            <% } %>
            <button type="submit" class="btn btn-indigo rounded-3 w-100">Add</button>
          </form>
        </div>
      </div>
      <div class="col-lg-8">
        <div class="card-plain">
          <h6 class="fw-bold mb-3"><%= page === 'courses' ? 'All Courses' : 'All Subjects' %></h6>
          <table class="table table-plain">
            <thead><tr><th>Name</th><% if (page === 'subjects') { %><th>Course</th><% } %><th></th></tr></thead>
            <tbody>
              <% if (page === 'courses') { %>
                <% data.courses.forEach(c => { %>
                  <tr>
                    <td><%= c.name %></td>
                    <td class="text-end">
                      <a href="/app?page=courses&delete=1&table=courses&id=<%= c._id %>" class="text-danger" onclick="return confirm('Delete this course?')"><i class="fa-solid fa-trash"></i></a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <% data.subjects.forEach(s => { %>
                  <tr>
                    <td><%= s.name %></td>
                    <td><%= s.course_id ? s.course_id.name : '-' %></td>
                    <td class="text-end">
                      <a href="/app?page=subjects&delete=1&table=subjects&id=<%= s._id %>" class="text-danger" onclick="return confirm('Delete this subject?')"><i class="fa-solid fa-trash"></i></a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  <% } else if (page === 'manage_staff' || page === 'manage_students') { %>
    <div class="card-plain">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0"><%= page === 'manage_staff' ? 'Staff Members' : 'Students' %></h6>
        <button class="btn btn-indigo rounded-3" data-bs-toggle="modal" data-bs-target="#addModal">
          <i class="fa-solid fa-plus me-1"></i> Add New
        </button>
      </div>
      <table class="table table-plain">
        <thead>
          <tr>
            <th></th><th>Name</th><th>Email</th><th>Gender</th>
            <% if (page === 'manage_students') { %><th>Course</th><% } %>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% const list = page === 'manage_staff' ? data.staffs : data.students; %>
          <% list.forEach(u => { %>
            <tr>
              <td><img class="avatar-sm" src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(u.full_name) %>&background=6366F1&color=fff"></td>
              <td><%= u.full_name %></td>
              <td><%= u.email %></td>
              <td><%= u.gender %></td>
              <% if (page === 'manage_students') { %><td><%= u.course_id ? u.course_id.name : '-' %></td><% } %>
              <td class="text-end">
                <a href="/app?page=<%= page %>&delete=1&table=<%= page === 'manage_staff' ? 'staff' : 'students' %>&id=<%= u._id %>" class="text-danger" onclick="return confirm('Delete this user?')"><i class="fa-solid fa-trash"></i></a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="modal fade" id="addModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 20px;">
          <div class="modal-header">
            <h5 class="modal-title fw-bold">Add New <%= page === 'manage_staff' ? 'Staff' : 'Student' %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <form method="POST" action="/app?page=<%= page %>">
            <div class="modal-body">
              <input type="hidden" name="action" value="<%= page === 'manage_staff' ? 'add_staff' : 'add_student' %>">
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="full_name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Gender</label>
                <select name="gender" class="form-select">
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <% if (page === 'manage_students') { %>
                <div class="mb-3">
                  <label class="form-label">Course</label>
                  <select name="course_id" class="form-select">
                    <% data.courses.forEach(c => { %>
                      <option value="<%= c._id %>"><%= c.name %></option>
                    <% }) %>
                  </select>
                </div>
              <% } %>
              <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea name="address" class="form-control" rows="2"></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-indigo rounded-3">Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>

  <% } else if (page === 'manage_attendance' || page === 'take_attendance') { %>
    <div class="card-plain mb-3">
      <h6 class="fw-bold mb-3">Filter</h6>
      <form method="GET" action="/app" class="row g-3 align-items-end">
        <input type="hidden" name="page" value="<%= page %>">
        <div class="col-md-3">
          <label class="form-label">Date</label>
          <input type="date" name="fetch_date" class="form-control" value="<%= data.fetch_date || '' %>" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Course</label>
          <select name="fetch_course" class="form-select" required>
            <% data.courses.forEach(c => { %>
              <option value="<%= c._id %>" <%= data.fetch_course == c._id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Subject</label>
          <select name="fetch_subject" class="form-select" required>
            <% data.subjects.forEach(s => { %>
              <option value="<%= s._id %>" <%= data.fetch_subject == s._id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-indigo rounded-3 w-100">Fetch</button>
        </div>
      </form>
    </div>

    <% if (data.fetched_students && data.fetched_students.length > 0) { %>
      <div class="card-plain">
        <form method="POST" action="/app?page=<%= page %>">
          <input type="hidden" name="action" value="save_attendance">
          <input type="hidden" name="date" value="<%= data.fetch_date %>">
          <input type="hidden" name="course_id" value="<%= data.fetch_course %>">
          <input type="hidden" name="subject_id" value="<%= data.fetch_subject %>">
          <table class="table table-plain">
            <thead><tr><th>Student</th><th>Present</th><th>Absent</th></tr></thead>
            <tbody>
              <% data.fetched_students.forEach(s => { %>
                <% const currentStatus = data.existing_attendance[s._id.toString()] || 'Present'; %>
                <tr>
                  <td><%= s.full_name %></td>
                  <td><input type="radio" name="attendance[<%= s._id %>]" value="Present" <%= currentStatus === 'Present' ? 'checked' : '' %>></td>
                  <td><input type="radio" name="attendance[<%= s._id %>]" value="Absent" <%= currentStatus === 'Absent' ? 'checked' : '' %>></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <button type="submit" class="btn btn-indigo rounded-3 mt-2">Save Attendance</button>
        </form>
      </div>
    <% } %>

  <% } else if (page === 'manage_exams') { %>
    <div class="card-plain mb-3">
      <h6 class="fw-bold mb-3">Filter</h6>
      <form method="GET" action="/app" class="row g-3 align-items-end">
        <input type="hidden" name="page" value="manage_exams">
        <div class="col-md-4">
          <label class="form-label">Course</label>
          <select name="fetch_course" class="form-select" required>
            <% data.courses.forEach(c => { %>
              <option value="<%= c._id %>" <%= data.fetch_course == c._id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Subject</label>
          <select name="fetch_subject" class="form-select" required>
            <% data.subjects.forEach(s => { %>
              <option value="<%= s._id %>" <%= data.fetch_subject == s._id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-indigo rounded-3 w-100">Fetch</button>
        </div>
      </form>
    </div>

    <% if (data.exam_students && data.exam_students.length > 0) { %>
      <div class="card-plain">
        <form method="POST" action="/app?page=manage_exams">
          <input type="hidden" name="action" value="save_scores">
          <input type="hidden" name="subject_id" value="<%= data.fetch_subject %>">
          <table class="table table-plain">
            <thead><tr><th>Student</th><th>Score (0-100)</th></tr></thead>
            <tbody>
              <% data.exam_students.forEach(s => { %>
                <tr>
                  <td><%= s.full_name %></td>
                  <td><input type="number" min="0" max="100" name="score[<%= s._id %>]" class="form-control" value="<%= data.existing_scores[s._id.toString()] !== undefined ? data.existing_scores[s._id.toString()] : '' %>"></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <button type="submit" class="btn btn-indigo rounded-3 mt-2">Save Scores</button>
        </form>
      </div>
    <% } %>

  <% } else if (page === 'apply_leave') { %>
    <div class="row g-3">
      <div class="col-lg-5">
        <div class="card-plain">
          <h6 class="fw-bold mb-3">Apply for Leave</h6>
          <form method="POST" action="/app?page=apply_leave">
            <input type="hidden" name="action" value="apply_leave">
            <div class="mb-3">
              <label class="form-label">Date</label>
              <input type="date" name="date" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Reason</label>
              <textarea name="message" class="form-control" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-indigo rounded-3 w-100">Submit Request</button>
          </form>
        </div>
      </div>
      <div class="col-lg-7">
        <div class="card-plain">
          <h6 class="fw-bold mb-3">My Leave History</h6>
          <table class="table table-plain">
            <thead><tr><th>Date</th><th>Message</th><th>Status</th></tr></thead>
            <tbody>
              <% data.my_leaves.forEach(l => { %>
                <tr>
                  <td><%= l.date %></td>
                  <td><%= l.message %></td>
                  <td><span class="status-pill status-<%= l.status.toLowerCase() %>"><%= l.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  <% } else if (page === 'notifications') { %>
    <div class="card-plain">
      <h6 class="fw-bold mb-3">Leave Requests</h6>
      <table class="table table-plain">
        <thead><tr><th>Name</th><th>Role</th><th>Date</th><th>Message</th><th>Status</th><th></th></tr></thead>
        <tbody>
          <% data.leaves.forEach(l => { %>
            <tr>
              <td><%= l.user_id ? l.user_id.full_name : '-' %></td>
              <td><span class="badge bg-secondary"><%= l.role %></span></td>
              <td><%= l.date %></td>
              <td><%= l.message %></td>
              <td><span class="status-pill status-<%= l.status.toLowerCase() %>"><%= l.status %></span></td>
              <td>
                <% if (l.status === 'Pending') { %>
                  <form method="POST" action="/app?page=notifications" class="d-inline">
                    <input type="hidden" name="action" value="update_leave">
                    <input type="hidden" name="leave_id" value="<%= l._id %>">
                    <input type="hidden" name="status" value="Approved">
                    <button type="submit" class="btn btn-sm btn-success rounded-3"><i class="fa-solid fa-check"></i></button>
                  </form>
                  <form method="POST" action="/app?page=notifications" class="d-inline">
                    <input type="hidden" name="action" value="update_leave">
                    <input type="hidden" name="leave_id" value="<%= l._id %>">
                    <input type="hidden" name="status" value="Declined">
                    <button type="submit" class="btn btn-sm btn-danger rounded-3"><i class="fa-solid fa-xmark"></i></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } else if (page === 'notify') { %>
    <div class="card-plain" style="max-width: 560px;">
      <h6 class="fw-bold mb-3">Send Notification</h6>
      <form method="POST" action="/app?page=notify">
        <input type="hidden" name="action" value="send_notification">
        <div class="mb-3">
          <label class="form-label">Audience</label>
          <select name="type" class="form-select">
            <option value="student">Students</option>
            <option value="staff">Staff</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Message</label>
          <textarea name="message" class="form-control" rows="4" required></textarea>
        </div>
        <button type="submit" class="btn btn-indigo rounded-3 w-100">Send</button>
      </form>
    </div>

  <% } else if (page === 'staff_notifs' || page === 'student_notifs') { %>
    <% if (data.notifs && data.notifs.length > 0) { %>
      <% data.notifs.forEach(n => { %>
        <div class="notif-card">
          <i class="fa-solid fa-bell"></i>
          <div>
            <p class="n-msg"><%= n.message %></p>
            <div class="n-time"><%= new Date(n.created_at).toLocaleString() %></div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="alert alert-secondary">No new notices.</div>
    <% } %>

  <% } else if (page === 'view_attendance' || page === 'my_attendance') { %>
    <div class="card-plain">
      <h6 class="fw-bold mb-3"><%= page === 'view_attendance' ? 'Attendance Logs' : 'My Attendance' %></h6>
      <table class="table table-plain">
        <thead>
          <tr>
            <% if (page === 'view_attendance') { %><th>Student</th><% } %>
            <th>Subject</th><th>Date</th><th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% const attLogs = page === 'view_attendance' ? data.logs : data.my_att; %>
          <% attLogs.forEach(a => { %>
            <tr>
              <% if (page === 'view_attendance') { %><td><%= a.student_id ? a.student_id.full_name : '-' %></td><% } %>
              <td><%= a.subject_id ? a.subject_id.name : '-' %></td>
              <td><%= a.date %></td>
              <td><span class="status-pill status-<%= a.status.toLowerCase() %>"><%= a.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } else if (page === 'exam_results') { %>
    <% if (data.scores && data.scores.length > 0) { %>
      <div class="row g-3">
        <% data.scores.forEach(s => { %>
          <div class="col-md-4">
            <div class="exam-card">
              <div class="text-muted small mb-2"><%= s.subject_id ? s.subject_id.name : '-' %></div>
              <div class="score-num"><%= s.score %></div>
              <div class="text-muted small">out of 100</div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info">No exam scores available yet.</div>
    <% } %>

  <% } else if (page === 'feedback') { %>
    <div class="card-plain" style="max-width: 560px;">
      <h6 class="fw-bold mb-3">Send Feedback</h6>
      <form method="POST" action="/app?page=feedback">
        <input type="hidden" name="action" value="send_feedback">
        <div class="mb-3">
          <label class="form-label">Your Message</label>
          <textarea name="message" class="form-control" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-indigo rounded-3 w-100">Submit Feedback</button>
      </form>
    </div>

  <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<% if (page === 'dashboard') { %>
<script>
  const attCtx = document.getElementById('attendanceChart');
  if (attCtx) {
    new Chart(attCtx, {
      type: 'line',
      data: {
        labels: Array.from({length: 31}, (_, i) => i + 1),
        datasets: [
          {
            label: 'Present',
            data: [22,25,24,26,28,27,29,30,28,26,27,29,31,30,28,27,29,30,32,31,29,28,30,31,33,32,30,29,31,32,34],
            borderColor: '#00B87C',
            backgroundColor: 'rgba(0,184,124,0.08)',
            tension: 0.35,
            fill: true,
            pointRadius: 0
          },
          {
            label: 'Absent',
            data: [8,6,7,5,4,5,3,2,4,6,5,3,1,2,4,5,3,2,0,1,3,4,2,1,-1,0,2,3,1,0,-2].map(v => Math.max(v,0)),
            borderColor: '#FF4C61',
            backgroundColor: 'rgba(255,76,97,0.08)',
            tension: 0.35,
            fill: true,
            pointRadius: 0
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        scales: { y: { beginAtZero: true } }
      }
    });
  }

  const perfCtx = document.getElementById('performanceChart');
  if (perfCtx) {
    new Chart(perfCtx, {
      type: 'doughnut',
      data: {
        labels: ['Excellent', 'Good', 'Needs Work'],
        datasets: [{
          data: [45, 35, 20],
          backgroundColor: ['#00B87C', '#0075FF', '#FF4C61'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } }
      }
    });
  }
</script>
<% } %>

</body>
</html>
